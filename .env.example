# GrowthBot local/staging secret template.
# Copy to .env and fill values locally. Do not commit .env.

# Required before Telegram Mini App staging can verify real initData or set webhook.
TELEGRAM_BOT_TOKEN=

# Required to protect Admin API on Cloudflare staging/prod.
# Generate with:
# openssl rand -base64 48 | tr -d '\n' && echo
ADMIN_TOKEN=

# Optional until signed app sessions are implemented.
JWT_SECRET=
ADMIN_JWT_SECRET=

# Cloudflare staging URLs.
VITE_API_BASE=https://api.growthbot.smt.it.com
MINIAPP_STAGING_URL=https://app.growthbot.smt.it.com
ADMIN_STAGING_URL=https://admin.growthbot.smt.it.com

# Optional future integrations, not required for V0 off-chain staging.
# Use testnet first for Agentic Wallet experiments and transaction-writing features.
TON_NETWORK=testnet
TON_API_KEY_TESTNET=
TON_API_KEY_MAINNET=
TON_API_KEY=
OPENAI_API_KEY=
