{
  "name": "growthbot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev:api",
    "dev:api": "npm --workspace @growthbot/api-worker run dev",
    "dev:miniapp": "npm --workspace @growthbot/miniapp run dev",
    "dev:admin": "npm --workspace @growthbot/admin run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "smoke:api": "node scripts/smoke-api.mjs",
    "compile:skill-runtimes": "node scripts/compile-runtimes.mjs",
    "verify:skill-runtime-sync": "node scripts/verify-skill-runtime-sync.mjs",
    "verify:admin-api": "node scripts/verify-admin-api.mjs",
    "verify:skill-card-lifecycle": "node scripts/verify-skill-card-lifecycle.mjs",
    "verify:agent-core": "node scripts/verify-agent-core.mjs",
    "verify:agent-workflow": "node scripts/verify-agent-workflow.mjs",
    "verify:box-store": "node scripts/verify-box-store.mjs",
    "verify:agent-wallet": "node scripts/verify-agent-wallet.mjs",
    "verify:agent-skill-core": "node scripts/verify-agent-skill-core.mjs",
    "verify:skill-economy": "node scripts/verify-skill-economy.mjs",
    "verify:skill-catalog": "node scripts/verify-skill-catalog.mjs",
    "verify:skill-runtime-spec-v1": "node scripts/verify-skill-runtime-spec-v1.mjs",
    "compile-runtimes": "node scripts/compile-runtimes.mjs",
    "verify:skill-runtime-lite": "node scripts/verify-skill-runtime-lite.mjs",
    "verify:launch-v1": "npx tsx scripts/verify-launch-v1.mjs",
    "verify:static-v1": "npm run typecheck && node scripts/verify-migration-sync.mjs && node scripts/verify-skill-economy-migration.mjs && node scripts/verify-skill-runtime-sync.mjs",
    "verify:integration-v1": "node scripts/verify-agent-core.mjs && node scripts/verify-agent-workflow.mjs && node scripts/verify-box-store.mjs && node scripts/verify-box-store-concurrency.mjs && node scripts/verify-agent-wallet.mjs && node scripts/verify-agent-skill-core.mjs && node scripts/verify-skill-economy.mjs && node scripts/verify-skill-catalog.mjs && node scripts/verify-skill-runtime-lite.mjs",
    "backup:launch": "node scripts/export-d1-launch-snapshot.mjs",
    "deploy:api:staging": "npm --workspace @growthbot/api-worker run deploy:staging",
    "deploy:api:prod": "npm --workspace @growthbot/api-worker run deploy:prod",
    "deploy:miniapp:staging": "npm --workspace @growthbot/miniapp run build && npx wrangler pages deploy apps/miniapp/dist --project-name=growthbot-miniapp --branch=staging",
    "deploy:admin:staging": "npm --workspace @growthbot/admin run build && npx wrangler pages deploy apps/admin/dist --project-name=growthbot-admin --branch=staging",
    "deploy:pages:staging": "npm run deploy:miniapp:staging && npm run deploy:admin:staging",
    "verify:workflow-runtime-settlement-migration": "node scripts/verify-workflow-runtime-settlement-migration.mjs",
    "verify:workflow-runtime-settlement": "npm run verify:workflow-runtime-settlement-migration && node scripts/verify-agent-workflow.mjs",
    "verify:research-brief-runtime": "node scripts/verify-research-brief-runtime.mjs",
    "verify:production-migration-remediation": "node scripts/verify-production-migration-remediation.mjs",
    "verify:production-migration-clone": "node scripts/verify-production-migration-clone.mjs",
    "build:production-d1-remediation": "node scripts/build-production-d1-remediation.mjs",
    "verify:production-d1-custom-remediation": "node scripts/verify-production-d1-custom-remediation.mjs",
    "verify:research-brief-migration": "node scripts/verify-research-brief-migration.mjs",
    "preflight:production-migrations": "node scripts/preflight-production-migrations-0006-0016.mjs",
    "verify:cloudflare-environment-isolation": "node scripts/verify-cloudflare-environment-isolation.mjs",
    "verify:cloudflare-deploy-ready": "node scripts/assert-cloudflare-deploy-ready.mjs production",
    "verify:production-runtime-compat-v1": "node scripts/verify-production-runtime-compat-v1.mjs",
    "verify:work-report": "node scripts/verify-work-report.mjs",
    "verify:real-asset-agent-v1": "node scripts/verify-real-asset-agent-v1.mjs",
    "verify:real-asset-db-persistence-v1": "node scripts/verify-real-asset-db-persistence-v1.mjs",
    "verify:runtime-db-wiring-v1": "node scripts/verify-runtime-db-wiring-v1.mjs",
    "verify:launch-readiness-v1": "node scripts/verify-launch-readiness-v1.mjs",
    "verify:real-asset-admin-route-mount-v1": "node scripts/verify-real-asset-admin-route-mount-v1.mjs",
    "verify:production-d1-smoke-readiness-v1": "node scripts/verify-production-d1-smoke-readiness-v1.mjs",
    "verify:launch-readiness-report-v1": "node scripts/verify-launch-readiness-report-v1.mjs",
    "verify:production-d1-divergence-remediation-plan-v1": "node scripts/verify-production-d1-divergence-remediation-plan-v1.mjs",
    "verify:telegram-webhook": "npx tsx scripts/verify-telegram-webhook-skeleton.mjs",
    "verify:telegram-d1-schema": "node scripts/verify-telegram-d1-schema.mjs",
    "verify:telegram-source-api": "npx tsx scripts/verify-telegram-source-api.mjs",
    "verify:telegram-opportunity-api": "npx tsx scripts/verify-telegram-opportunity-api.mjs",
    "verify:telegram-webhook-persistence": "npx tsx scripts/verify-telegram-webhook-persistence.mjs",
    "verify:telegram-production-readiness": "npx tsx scripts/verify-telegram-production-readiness.mjs",
    "verify:pet-agent-copy": "node scripts/verify-pet-agent-copy.mjs"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
